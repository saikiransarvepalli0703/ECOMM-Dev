  { id:10, name:'Speedmaster Moonwatch',  brand:'Omega',            category:'Watches',   price:450000,  old:null,    emoji:'⌚', rating:5, badge:'Heritage',  desc:'First watch on the moon.' },
  { id:11, name:'Neverfull MM',           brand:'Louis Vuitton',    category:'Bags',      price:165000,  old:180000,  emoji:'👜', rating:4, badge:'Sale',      desc:'Iconic monogram tote.' },
  { id:12, name:'Oud Wood 50ml',          brand:'Tom Ford',         category:'Fragrance', price:24000,   old:null,    emoji:'🌸', rating:5, badge:'Luxe',      desc:'Rare and precious oud.' },
  { id:13, name:'Triple S Sneakers',      brand:'Balenciaga',       category:'Shoes',     price:88000,   old:95000,   emoji:'👟', rating:4, badge:'Sale',      desc:'Chunky sole statement shoe.' },
  { id:14, name:'Diamond Tennis Bracelet',brand:'Tiffany & Co.',    category:'Jewellery', price:320000,  old:null,    emoji:'💎', rating:5, badge:'Fine',      desc:'Round brilliant diamonds.' },
  { id:15, name:'Perpetual Calendar',     brand:'Patek Philippe',   category:'Watches',   price:3500000, old:null,    emoji:'⌚', rating:5, badge:'Masterpiece',desc:'The pinnacle of horology.' },
  { id:16, name:'Kelly 28',              brand:'Hermès',            category:'Bags',      price:1050000, old:null,    emoji:'👜', rating:5, badge:'Rare',      desc:'Grace Kelly's favourite.' },
];

let cart = [];
let wishlist = new Set();
let activeFilter = 'All';
let activePage = 'home';

// ── PAGES ────────────────────────────────────────────────────────────────────
function showPage(page) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + page).classList.add('active');
  document.querySelectorAll('.nav-links a').forEach(a => a.classList.remove('active'));
  const navEl = document.getElementById('nav-' + page);
  if (navEl) navEl.classList.add('active');
  activePage = page;
  window.scrollTo(0, 0);
  if (page === 'shop') renderShop();
  if (page === 'home') renderHome();
}

function filterCategory(cat) {
  showPage('shop');
  setFilter(cat, document.querySelector(`.filter-btn[onclick="setFilter('${cat}', this)"]`) || document.querySelector('.filter-btn'));
}

// ── RENDER ───────────────────────────────────────────────────────────────────
function renderProducts(list, containerId) {
  const el = document.getElementById(containerId);
  if (!el) return;
  if (!list.length) { el.innerHTML = '<div style="padding:60px;opacity:.4;font-size:.9rem;grid-column:1/-1">No products found.</div>'; return; }
  el.innerHTML = list.map((p, i) => `
    <div class="product-card" style="animation-delay:${i*0.06}s">
      <div class="product-img">
        ${p.badge ? `<div class="product-badge">${p.badge}</div>` : ''}
        <button class="wishlist-btn" onclick="toggleWishlist(${p.id}, event)">${wishlist.has(p.id) ? '❤️' : '🤍'}</button>
        <span>${p.emoji}</span>
        <div class="product-overlay">
          <button class="overlay-btn" onclick="addToCart(${JSON.stringify(p).replace(/"/g,"'")})">Add to Bag</button>
        </div>
      </div>
      <div class="product-info">
        <div class="product-name">${p.name}</div>
        <div class="product-brand">${p.brand}</div>
        <div class="product-footer">
          <div>
            ${p.old ? `<span class="product-old-price">₹${p.old.toLocaleString('en-IN')}</span>` : ''}
            <span class="product-price">₹${p.price.toLocaleString('en-IN')}</span>
          </div>
          <div class="product-rating">${renderStars(p.rating)}</div>
        </div>
      </div>
    </div>
  `).join('');
}

function renderStars(r) {
  return Array.from({length:5}, (_,i) => `<span class="star${i<r?'':' empty'}">★</span>`).join('');
}

function renderHome() {
  renderProducts(products.slice(0,8), 'homeProducts');
}

let shopList = [...products];
function renderShop() {
  let list = activeFilter === 'All' ? [...products] : products.filter(p => p.category === activeFilter);
  shopList = list;
  renderProducts(list, 'shopProducts');
}

function setFilter(cat, btn) {
  activeFilter = cat;
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  if (btn) btn.classList.add('active');
  showPage('shop');
}

function sortProducts(val) {
  let list = [...shopList];
  if (val === 'priceLow')  list.sort((a,b) => a.price - b.price);
  if (val === 'priceHigh') list.sort((a,b) => b.price - a.price);
  if (val === 'rating')    list.sort((a,b) => b.rating - a.rating);
  renderProducts(list, 'shopProducts');
}

// ── CART ─────────────────────────────────────────────────────────────────────
function addToCart(p) {
  const product = typeof p === 'string' ? JSON.parse(p.replace(/'/g,'"')) : p;
  const exists = cart.find(c => c.id === product.id);
  if (exists) exists.qty++;
  else cart.push({ ...product, qty: 1 });
  updateCart();
  showToast('Added to bag — ' + product.name);
  toggleCart(true);
}

function removeFromCart(id) {
  cart = cart.filter(c => c.id !== id);
  updateCart();
}

function changeQty(id, delta) {
  const item = cart.find(c => c.id === id);
  if (!item) return;
  item.qty += delta;
  if (item.qty <= 0) return removeFromCart(id);
  updateCart();
}

function updateCart() {
  const count = cart.reduce((s,c) => s + c.qty, 0);
  document.getElementById('cartCount').textContent = count;
  const total = cart.reduce((s,c) => s + c.price * c.qty, 0);
  document.getElementById('cartTotal').textContent = '₹' + total.toLocaleString('en-IN');

  const el = document.getElementById('cartItems');
  const empty = document.getElementById('emptyCart');
  const footer = document.getElementById('cartFooter');

  if (!cart.length) {
    empty.style.display = 'flex';
    footer.style.display = 'none';
    el.innerHTML = '';
    el.appendChild(empty);
    return;
  }
  empty.style.display = 'none';
  footer.style.display = 'block';
  el.innerHTML = cart.map(c => `
    <div class="cart-item">
      <div class="cart-item-img">${c.emoji}</div>
      <div class="cart-item-info">
        <div class="cart-item-name">${c.name}</div>
        <div class="cart-item-brand">${c.brand}</div>
        <div class="cart-item-footer">
          <span class="cart-item-price">₹${(c.price*c.qty).toLocaleString('en-IN')}</span>
          <div class="qty-ctrl">
            <button class="qty-btn" onclick="changeQty(${c.id},-1)">−</button>
            <span class="qty-val">${c.qty}</span>
            <button class="qty-btn" onclick="changeQty(${c.id},1)">+</button>
            <button class="remove-btn" onclick="removeFromCart(${c.id})">✕</button>
          </div>
        </div>
      </div>
    </div>
  `).join('');
}

function toggleCart(forceOpen) {
  const sidebar = document.getElementById('cartSidebar');
  const overlay = document.getElementById('cartOverlay');
  const isOpen = sidebar.classList.contains('open');
  if (forceOpen === true && isOpen) return;
  sidebar.classList.toggle('open');
  overlay.classList.toggle('open');
}

function checkout() {
  if (!cart.length) return;
  showToast('🎉 Order placed! Thank you for shopping with LUXE.');
  cart = [];
  updateCart();
  toggleCart();
}

// ── WISHLIST ─────────────────────────────────────────────────────────────────
function toggleWishlist(id, e) {
  e.stopPropagation();
  wishlist.has(id) ? wishlist.delete(id) : wishlist.add(id);
  renderHome(); renderShop();
  showToast(wishlist.has(id) ? 'Added to wishlist ❤️' : 'Removed from wishlist');
}

// ── SEARCH ───────────────────────────────────────────────────────────────────
function toggleSearch() {
  document.getElementById('searchWrapper').classList.toggle('open');
  setTimeout(() => document.getElementById('searchInput').focus(), 100);
}
function closeSearch(e) {
  if (e.target === document.getElementById('searchWrapper')) {
    document.getElementById('searchWrapper').classList.remove('open');
  }
}
function handleSearch(val) {
  const q = val.toLowerCase().trim();
  if (!q) { document.getElementById('searchHint').textContent = 'Press ESC to close'; return; }
  const results = products.filter(p =>
    p.name.toLowerCase().includes(q) ||
    p.brand.toLowerCase().includes(q) ||
    p.category.toLowerCase().includes(q)
  );
  document.getElementById('searchHint').textContent =
    results.length ? `${results.length} result(s) found — press Enter to view` : 'No results found';
}
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    document.getElementById('searchWrapper').classList.remove('open');
  }
  if (e.key === 'Enter' && document.getElementById('searchWrapper').classList.contains('open')) {
    const q = document.getElementById('searchInput').value.toLowerCase().trim();
    if (!q) return;
    activeFilter = 'All';
    showPage('shop');
    document.getElementById('searchWrapper').classList.remove('open');
    const list = products.filter(p =>
      p.name.toLowerCase().includes(q) ||
      p.brand.toLowerCase().includes(q) ||
      p.category.toLowerCase().includes(q)
    );
    renderProducts(list, 'shopProducts');
  }
});

// ── TOAST ────────────────────────────────────────────────────────────────────
let toastTimer;
function showToast(msg) {
  const t = document.getElementById('toast');
  document.getElementById('toastMsg').textContent = msg;
  t.classList.add('show');
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove('show'), 2800);
}

// ── INIT ─────────────────────────────────────────────────────────────────────
renderHome();
</script>
