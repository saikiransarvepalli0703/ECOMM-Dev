<script>
// ── PRODUCTS DATA ────────────────────────────────────────────────────────────
const products = [
  { id:1,  name:'Royal Oak Chronograph',  brand:'Audemars Piguet', category:'Watches',   price:1850000, old:2100000, emoji:'⌚', rating:5, badge:'Iconic',    desc:'Swiss luxury sport watch.' },
