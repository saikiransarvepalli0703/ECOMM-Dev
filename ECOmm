  { id:4,  name:'Air Force 1 Craft',      brand:'Nike',             category:'Shoes',     price:12500,   old:null,    emoji:'👟', rating:4, badge:'New',       desc:'Premium white leather sneaker.' },
  { id:5,  name:'Submariner Date',        brand:'Rolex',            category:'Watches',   price:980000,  old:null,    emoji:'⌚', rating:5, badge:'Iconic',    desc:'The definitive dive watch.' },
  { id:6,  name:'Classic Flap Medium',    brand:'Chanel',           category:'Bags',      price:750000,  old:820000,  emoji:'👜', rating:5, badge:'Timeless',  desc:'Quilted lambskin perfection.' },
  { id:7,  name:'N°5 Eau de Parfum',      brand:'Chanel',           category:'Fragrance', price:18000,   old:null,    emoji:'🌸', rating:5, badge:'Legendary', desc:'The world's most famous scent.' },
  { id:8,  name:'Stiletto Pump 90mm',     brand:'Christian Louboutin',category:'Shoes',   price:65000,   old:78000,   emoji:'👠', rating:4, badge:'Sale',      desc:'The iconic red-sole heel.' },
